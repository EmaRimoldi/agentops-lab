# Copy to .env and fill in. Never commit .env.

# Optional Anthropic API key for direct Anthropic SDK use.
# Claude Code CLI runs normally use `claude auth login` instead.
ANTHROPIC_API_KEY=

# GPU assignment (override per-agent defaults)
# CUDA_VISIBLE_DEVICES=0  # set per-agent in config

# Experiment timing overrides
# EXPERIMENT_FIRST_TURN_TIMEOUT_SEC=300
# MAX_STARTUP_SEC=600
